    <link href="/Assets/client/eliah/fontawesome/all.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js"></script>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Spartan:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="//cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.css" />
    <link rel="stylesheet" type="text/css" href="//cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick-theme.css" />

    <link href="~/Assets/client/eliah/css/reset.css" rel="stylesheet" />
    <link href="/Assets/client/eliah/css/pre.css" rel="stylesheet" />
    <link href="/Assets/client/eliah/css/header-a.css" rel="stylesheet" />
    <link href="/Assets/client/eliah/css/footer-a.css" rel="stylesheet" />
    <link href="/Assets/client/eliah/css/blog.css" rel="stylesheet" />
    <link href="/Assets/client/eliah/css/single-post.css" rel="stylesheet" />
    <link href="/Assets/client/eliah/css/single-post1.css" rel="stylesheet" />
    <link href="/Assets/client/eliah/css/blog2.css" rel="stylesheet" />
    <link href="/Assets/client/css/clientStyle.css" rel="stylesheet" />

    <script type="text/javascript">
        $(function () {
            $("#abc11").submit(function () {
                if (this.name.value == "") {
                } else {
                    alert("Đăng ký nhận tin thành công!");
                    document.getElementById("form-get-it").reset();
                }
                return false;
            });
        });

        $(document).ready(function () {
            $(document).mouseup(function (e) {
                var container = $(".top-bar__search");
                if (!container.is(e.target) && container.has(e.target).length === 0) {
                    container.hide();
                }
            });

            $(".post-wish, .post-wish1, .post-wish2, .post-wish3, .post-wish4, .post-wish5, .post-wish6").click(function () {
                $(this).children("i").css('color', '#f26460');
            });

            $("#show__search-input").click(function () {
                $(".top-bar__search").show();
                $(".top-bar__search").css('display', 'flex');
            });

            $(".top-bar__icon-cart, .cart-quantity").click(function () {
                $(".inside-cart").show();
                $(".inside-cart").css('opacity', '1');
                $("#overlay").css('display', 'block');
            });

            $("#overlay").click(function () {
                $(".inside-cart").hide();
                $("#overlay").hide();
            });

            $("#btn-show-menu").click(function () {
                $(".top-bar__menu").css('left', '0');
            });

            $("#btn-times").click(function () {
                $(".top-bar__menu").css('left', '-100%');
            });
        });
    </script>
</head>
<body>
   
    <header>
        <section class="top-bar">
            <div class="top-bar__content">
                <div>
                    <div class="top-bar__logo">
                        <h1>Võ Huy Khánh</h1>
                    </div>
                    <div class="top-bar__menu">
                        <ul>
                            <i id="btn-times" class="far fa-times"></i>
                            <li>
                                <a href="https://localhost:44356/">Trang chủ</a>
                            </li>
                            <li id="item-home" style="position: relative;">
                                <a href="https://localhost:44356/">Chuyên mục</a>
                                <div style="z-index: 888;" class="menu-home">
                                    <a href="https://localhost:44356/"><div><span></span>Chôl Chnăm Thmây</div></a>
                                    <a href="https://localhost:44356/"><div><span></span>Lễ Oóc Ôm Bóc</div></a>
                                    <a href="https://localhost:44356/"><div><span></span>Lễ Sene Dolta</div></a>
                                    <a href="https://localhost:44356/"><div><span></span>Đua Ghe Ngo</div></a>
                                    <a href="https://localhost:44356/"><div><span></span>Văn hóa & Ẩm thực</div></a>
                                </div>
                            </li>
                            @if (Session["USER_SESSION"] != null)
                            {
                                DataAccess.EntityFramework.account acc = Session["USER_SESSION"] as DataAccess.EntityFramework.account;
                                <li>Xin chào @acc.full_name</li>
                                <li><a href="@Url.Action("Logout", "Account")">Thoát</a></li>
                            }
                            else
                            {
                                <li><a href="@Url.Action("Login", "Account")">Đăng nhập</a></li>
                                <li><a href="@Url.Action("Register", "Account")">Đăng ký</a></li>
                            }
                        </ul>
                    </div>
                    <div class="top-bar__cart">
                        <div id="show__search-input" style="position: relative;">
                            <i class="fal fa-search stt"></i>
                            <div class="tool-tip-search">
                                Tìm kiếm bài viết
                                <div></div>
                            </div>
                            <div class="top-bar__search">
                                @using (Html.BeginForm("Index", "HomePage", FormMethod.Get, new { @class = "search1-form" }))
                                {
                                    @Html.TextBox("searchst", null, new { id = "searchst", @class = "top-bar__search-input", placeholder = "Nhập từ khóa..." })
                                    <input id="btsearch" value="submit" style="display: none;" type="submit" />
                                    <label style="position: absolute; top: 8px; right: -20px;" for="btsearch"><i class="fal fa-search"></i></label>
                                }
                            </div>
                        </div>

                        <div class="top-bar__shopping-cart">
                            <div class="top-bar__icon-cart">
                                <a>
                                    <i style="font-size: 25px; " class="fal fa-bookmark"></i>
                                </a>
                            </div>
                            
                            <div id="overlay"></div>
                            <div class="inside-cart">
                                <div class="title-hover-carts">
                                    Bài viết đã lưu
                                </div>
                                <div class="list-pro-hover-carts">
                                    <div class="pro-hover-carts">
                                        <div>
                                            <div class="show-detail-pro-incart">
                                                <img src="img/chol-chnam-thmay.jpg" alt="Chôl Chnăm Thmây">
                                            </div>
                                            <div>
                                                <a href="single-post1.html">
                                                    <div class="pro-hover-carts-title ">
                                                        Ý nghĩa của Tết Chôl Chnăm Thmây trong đời sống người Khmer
                                                    </div>
                                                </a>
                                                <div class="pro-hover-carts-quantity">
                                                    14 Tháng 4, 2024
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="pro-hover-carts">
                                        <div>
                                            <div class="show-detail-pro-incart">
                                                <img src="img/dua-ghe-ngo.jpg" alt="Đua Ghe Ngo">
                                            </div>
                                            <div>
                                                <a href="single-post1.html">
                                                    <div class="pro-hover-carts-title">
                                                        Náo nức không khí giải Đua Ghe Ngo truyền thống
                                                    </div>
                                                </a>
                                                <div class="pro-hover-carts-quantity">
                                                    20 Tháng 11, 2023
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <a href="blog2.html">
                                        <div class="button-view-all-post">
                                            XEM TẤT CẢ
                                        </div>
                                    </a>

                                </div>
                            </div>
                        </div>

                        <div class="button-bar">
                            <input type="checkbox" id="click-menu">
                            <label for="click-menu" id="menu-btn">
                                <i id="btn-show-menu" class="far fa-bars"></i>
                            </label>
                        </div>
                    </div>
                </div>
        </section>
    </header>

