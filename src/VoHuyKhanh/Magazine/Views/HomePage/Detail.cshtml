        </div>
        <div class="lsb__pp-post">
            <div>
                <img src="https://media-cdn-v2.laodong.vn/storage/newsportal/2023/12/16/1280755/Bun-Nuoc-Leo-2.jpg" alt="Ẩm thực" style="width: 80px; height: 80px; object-fit: cover; border-radius: 5px;">
            </div>
            <div class="title">
                <h3><a href="single-post1.html">Thưởng thức Bún Nước Lèo chuẩn vị người Khmer Sóc Trăng</a></h3>
                <span>12 Tháng 8, 2023</span>
            </div>
        </div>
    </div>
</div>

                        <div class="sidebar-widget">
                            <h2>Nhận bản tin</h2>
                            <p style="font-size: 13px; color: #666;">Đăng ký để nhận những bài viết mới nhất về văn hóa lễ hội truyền thống.</p>
                            <form id="abc11" action="" class="newsletter-form">
                                <input type="email" placeholder="Email của bạn" required>
                                <div>
                                    <input type="checkbox" id="cb-newsletter" required>
                                    <label for="cb-newsletter" style="font-weight: normal; font-size: 13px;">Tôi đồng ý với các điều khoản</label>
                                </div>
                                <input class="sub-butt" type="submit" value="ĐĂNG KÝ">
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </section>

    </main>

    <footer>
        <section class="footer-a">
            <div class="footer__content">
                <div class="footer__contact">
